doctype html
html
  head
    title Alle Restaurants
    link(rel="stylesheet", href="/style.css")
  body
    h1 Restaurants in Gent
    p Totaal gevonden: #{count}
    
    ul.restaurant-list
      each restaurant in restaurants
        li.card
          strong= restaurant.name
          p Locatie: #{restaurant.address}
          p Score: #{restaurant.rating} / 5
          p Keuken: #{restaurant.cuisine}
          p.sun-score Zon-intensiteit: #{restaurant.intensity}%
          a(href=`/api/restaurants/${restaurant._id}`) Bekijk details 